{
  "name": "full-vision-infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK Infrastructure for Full Vision App",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy:dev": "cdk deploy --profile default --context environment=dev",
    "deploy:prod": "cdk deploy --profile default --context environment=prod",
    "destroy:dev": "cdk destroy --profile default --context environment=dev",
    "destroy:prod": "cdk destroy --profile default --context environment=prod",
    "synth": "cdk synth",
    "bootstrap": "cdk bootstrap",
    "diff": "cdk diff"
  },
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "20.6.2",
    "aws-cdk": "2.1100.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "~5.2.2"
  },
  "dependencies": {
    "aws-cdk-lib": "2.233.0",
    "constructs": "^10.0.0",
    "dotenv": "^16.4.5",
    "source-map-support": "^0.5.21"
  },
  "keywords": [
    "aws",
    "cdk",
    "infrastructure",
    "full-vision",
    "optics"
  ]
}
