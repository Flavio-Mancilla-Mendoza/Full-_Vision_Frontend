# Example root environment variables for local development and documentation
# NOTE: Do NOT store secrets in the repository. Use Secrets Manager / SOPS for production secrets.

# Frontend (Vite) variables consumed in client code
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_GATEWAY_URL=
VITE_IMAGES_BASE_URL=
VITE_AWS_S3_IMAGES_BUCKET=
VITE_AWS_REGION=sa-east-1

# Supabase (server / lambda) - service role (sensitive, store in secret manager for prod)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Image / Storage
IMAGES_BUCKET_NAME=
S3_REGION=sa-east-1

# AWS / Infrastructure (non-secret examples; sensitive ARNs or keys should not be committed)
AWS_ACCOUNT=
AWS_REGION=sa-east-1
AWS_PROFILE=default

# App / env
ENVIRONMENT=dev
PROJECT_NAME=full-vision

# Optional monitoring / Sentry
SENTRY_DSN=

# Database settings (examples / non-secret)
DATABASE_ALLOCATED_STORAGE=20
DATABASE_MULTI_AZ=false
DATABASE_DELETION_PROTECTION=false
DATABASE_BACKUP_RETENTION=7

# Cognito / Auth behavior (examples)
COGNITO_PASSWORD_MIN_LENGTH=8
COGNITO_PASSWORD_REQUIRE_LOWERCASE=true
COGNITO_PASSWORD_REQUIRE_UPPERCASE=true
COGNITO_PASSWORD_REQUIRE_NUMBERS=true
COGNITO_PASSWORD_REQUIRE_SYMBOLS=true
COGNITO_MFA_CONFIGURATION=OPTIONAL

# Usage guidance (do not commit secrets):
# - Copy this file to `.env` locally and fill values for local development.
# - For production, store secrets in AWS Secrets Manager / Parameter Store or SOPS and reference them in CI/IaC.
# - Ensure `.env` is listed in `.gitignore`.
