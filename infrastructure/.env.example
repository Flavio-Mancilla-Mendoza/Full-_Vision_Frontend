# ================================================================
# AWS Configuration
# ================================================================
AWS_ACCOUNT=123456789012
AWS_REGION=sa-east-1
AWS_PROFILE=default

# ================================================================
# Environment Configuration
# ================================================================
ENVIRONMENT=dev
PROJECT_NAME=full-vision

# ================================================================
# Database Configuration
# ================================================================
DATABASE_ALLOCATED_STORAGE=20
DATABASE_MULTI_AZ=false
DATABASE_DELETION_PROTECTION=false
DATABASE_BACKUP_RETENTION=7

# ================================================================
# Cognito Configuration  
# ================================================================
COGNITO_PASSWORD_MIN_LENGTH=8
COGNITO_PASSWORD_REQUIRE_LOWERCASE=true
COGNITO_PASSWORD_REQUIRE_UPPERCASE=true
COGNITO_PASSWORD_REQUIRE_NUMBERS=true
COGNITO_PASSWORD_REQUIRE_SYMBOLS=true
COGNITO_MFA_CONFIGURATION=OPTIONAL

# ================================================================
# Storage Configuration
# ================================================================
STORAGE_ENABLE_VERSIONING=true
STORAGE_LIFECYCLE_RULES=true

# ================================================================
# ECS Configuration (for future weeks)
# ================================================================
ECS_DESIRED_CAPACITY=2
ECS_MIN_CAPACITY=1
ECS_MAX_CAPACITY=10
ECS_CPU=256
ECS_MEMORY=512

# ================================================================
# Networking Configuration
# ================================================================
NETWORKING_MAX_AZS=2
NETWORKING_ENABLE_NAT_GATEWAY=true

# ================================================================
# Monitoring Configuration
# ================================================================
MONITORING_ENABLE_DETAILED_MONITORING=true
MONITORING_LOG_RETENTION=30

# ================================================================
# Domain Configuration (Optional for production)
# ================================================================
# DOMAIN_NAME=fullvision.com
# SSL_CERTIFICATE_ARN=arn:aws:acm:sa-east-1:123456789012:certificate/abcd1234-...